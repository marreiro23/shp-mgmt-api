    {
      "name": "Create Sites",
      "item": [
        {
          "name": "Create Subsite",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Test Subsite {{$timestamp}}\",\n  \"name\": \"test-subsite-{{$timestamp}}\",\n  \"description\": \"Test subsite created via API\",\n  \"createType\": \"subsite\",\n  \"template\": \"STS#3\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/sites/{{parent_site_id}}/sites",
              "host": ["{{api_url}}"],
              "path": ["sites", "{{parent_site_id}}", "sites"]
            }
          },
          "description": "Criar um subsite em um site pai existente\n\nRequer:\n- parent_site_id: ID do site pai\n\nParâmetros opcionais:\n- template: Template do site (ex: STS#3 para Team Site)\n- createType: Deve ser 'subsite' (valor padrão)"
        },
        {
          "name": "Create Root Site (Global Marketing)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Global Marketing\",\n  \"name\": \"gm-root\",\n  \"description\": \"Root-level site para marketing global\",\n  \"createType\": \"root\",\n  \"template\": \"STS#3\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/sites/unused/sites",
              "host": ["{{api_url}}"],
              "path": ["sites", "unused", "sites"]
            }
          },
          "description": "Criar um site de nível root (não é subsite)\n\nExemplo: \"Global Marketing\" como site de raiz\n\nParâmetros:\n- createType: DEVE ser 'root'\n- displayName: Nome do site\n- name: Identificador único\n- template: Template do site (ex: STS#3)"
        },
        {
          "name": "Create Root Site (Team Site)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Engineering Team\",\n  \"name\": \"engineering-root\",\n  \"description\": \"Root team site para engenharia\",\n  \"createType\": \"root\",\n  \"template\": \"TEAMCHANNEL#0\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/sites/unused/sites",
              "host": ["{{api_url}}"],
              "path": ["sites", "unused", "sites"]
            }
          },
          "description": "Criar um site de nível root como Team Site\n\nVariante com template de Team Channel\n\nParâmetros:\n- createType: 'root'\n- template: 'TEAMCHANNEL#0' ou 'STS#3'"
        },
        {
          "name": "Clone Existing Site",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Marketing Clone {{$timestamp}}\",\n  \"name\": \"marketing-clone-{{$timestamp}}\",\n  \"description\": \"Clone of existing marketing site\",\n  \"createType\": \"clone\",\n  \"cloneFromSiteId\": \"example.sharepoint.com,00000000-0000-0000-0000-000000000000,00000000-0000-0000-0000-000000000000\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/sites/unused/sites",
              "host": ["{{api_url}}"],
              "path": ["sites", "unused", "sites"]
            }
          },
          "description": "Clonar um site existente como template\n\nCopia a estrutura e modelo de um site existente\n\nRequer:\n- cloneFromSiteId: ID do site a ser clonado\n\nParâmetros:\n- createType: DEVE ser 'clone'\n- displayName: Nome do novo site\n- name: Identificador único\n- description: Descrição (será incluida referência ao site de origem)"
        },
        {
          "name": "Clone as Subsite",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Sales Clone {{$timestamp}}\",\n  \"name\": \"sales-clone-{{$timestamp}}\",\n  \"description\": \"Clone of sales site under parent\",\n  \"createType\": \"clone\",\n  \"cloneFromSiteId\": \"example.sharepoint.com,00000000-0000-0000-0000-000000000000,00000000-0000-0000-0000-000000000000\",\n  \"parentSiteId\": \"parent-site-id-here\"\n}"
            },
            "url": {
              "raw": "{{api_url}}/sites/unused/sites",
              "host": ["{{api_url}}"],
              "path": ["sites", "unused", "sites"]
            }
          },
          "description": "Clonar um site como subsite dentro de um site pai\n\nCombina clonagem com criação de subsite\n\nParâmetros:\n- createType: 'clone'\n- cloneFromSiteId: Source site ID\n- parentSiteId: Parent site para criar como subsite"
        }
      ]
    },
