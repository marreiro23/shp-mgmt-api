{
  "info": {
    "name": "SharePoint Management API - shp-mgmt-api",
    "description": "Coleção completa de testes para API de gestão de SharePoint\n\nEndpoints para:\n- Listagem de sites, usuários, grupos e teams\n- Sincronização de recursos\n- Criação de sites (subsite, root level, por clonagem)\n- Interrogação de base de dados\n- Histórico de auditoria",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
