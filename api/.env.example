# Servidor
PORT=3001
HOST=localhost
NODE_ENV=development

# Azure AD / Microsoft Graph API (REQUIRED)
TENANT_ID=your-tenant-id
PRIMARY_DOMAIN=your-domain.onmicrosoft.com
CLIENT_ID=your-client-id
CERT_THUMBPRINT=your-cert-thumbprint
CERT_PRIVATE_KEY_PATH=../certs/sharepoint-file-manager-api.pem
GRAPH_SCOPE=https://graph.microsoft.com/.default
REQUEST_TIMEOUT_SECONDS=30
RETRY_ATTEMPTS=4

# CORS (separado por virgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Logging
LOG_LEVEL=info
LOG_FILE=../logs/api.log

# ──────────────────────────────────────────────────────────────────
# PostgreSQL (persistência de inventário e exports)
# Configurado por scripts/Initialize-Database.ps1
# Para Azure Flexible Server: PG_HOST=<server>.postgres.database.azure.com
#                             PG_SSL=true
#                             PG_USER=<usuario>@<server>
# ──────────────────────────────────────────────────────────────────
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=shp_mgmt_db
# PG_USER=shp_app_user
# PG_PASSWORD=
# PG_SSL=false
# PG_SCHEMA=shp
