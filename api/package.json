{
  "name": "shp-mgmt-api",
  "version": "3.0.0",
  "description": "SharePoint Management API via Microsoft Graph",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:lts": "npx -y node@20 server.js",
    "verify:ascii": "node ./scripts/verify-ascii.cjs --service shp-mgmt-api --root .",
    "verify:ascii:lts": "npx -y node@20 ./scripts/verify-ascii.cjs --service shp-mgmt-api --root .",
    "pretest": "npm run verify:ascii",
    "test": "mocha \"config/**/*.test.js\" \"test/**/*.test.js\" --reporter spec",
    "test:lts": "npx -y node@20 ./node_modules/mocha/bin/mocha \"config/**/*.test.js\" \"test/**/*.test.js\" --reporter spec",
    "test:watch": "mocha \"config/**/*.test.js\" \"test/**/*.test.js\" --reporter spec --watch",
    "generate:openapi": "echo OpenAPI generator not configured for current scope"
  },
  "keywords": [
    "SharePoint",
    "Graph",
    "Node",
    "SharePoint",
    "Microsoft Graph",
    "REST API"
  ],
  "author": "SharePoint Management API",
  "license": "LGPL-3.0",
  "dependencies": {
    "@azure/identity": "^4.0.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "isomorphic-fetch": "^3.0.0",
    "joi": "^17.12.2",
    "morgan": "^1.10.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "joi-to-swagger": "^6.2.0",
    "mocha": "^11.7.5",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=20.0.0 <21"
  }
}
